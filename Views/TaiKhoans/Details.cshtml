@model HeThongQuanLyPhongTro.Models.TaiKhoan

@{
    ViewData["Title"] = "Chi tiết tài khoản";
}

<div class="max-w-2xl mx-auto">
    <div class="bg-white rounded-xl shadow-md overflow-hidden">
        <!-- Header -->
        <div class="bg-gradient-to-r from-purple-500 to-purple-600 px-6 py-4">
            <div class="flex justify-between items-center">
                <div>
                    <h1 class="text-xl font-bold text-white">Chi tiết tài khoản</h1>
                    <p class="text-purple-100 text-sm">Mã tài khoản: @Model.MaTaiKhoan</p>
                </div>
                <a asp-action="Index" class="text-white hover:text-purple-200 transition-all">
                    <i class="fas fa-arrow-left mr-2"></i> Quay lại
                </a>
            </div>
        </div>

        <div class="p-6">
            <div class="bg-gray-50 rounded-lg p-5 mb-6">
                <h3 class="font-semibold text-gray-700 mb-3 flex items-center">
                    <i class="fas fa-user-circle text-purple-500 mr-2"></i>
                    Thông tin tài khoản
                </h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <p class="text-gray-500 text-sm">Mã tài khoản</p>
                        <p class="font-semibold">@Model.MaTaiKhoan</p>
                    </div>
                    <div>
                        <p class="text-gray-500 text-sm">Tên đăng nhập</p>
                        <p class="font-semibold text-lg">@Model.TenDangNhap</p>
                    </div>
                    <div>
                        <p class="text-gray-500 text-sm">Vai trò</p>
                        @if (Model.VaiTro == "Admin")
                        {
                            <span class="px-2 py-1 bg-purple-100 text-purple-700 rounded-full text-sm">
                                <i class="fas fa-crown"></i> Admin
                            </span>
                        }
                        else
                        {
                            <span class="px-2 py-1 bg-blue-100 text-blue-700 rounded-full text-sm">
                                <i class="fas fa-user"></i> Khách hàng
                            </span>
                        }
                    </div>
                    <div>
                        <p class="text-gray-500 text-sm">Trạng thái</p>
                        @if (Model.TrangThai == "Hoạt động")
                        {
                            <span class="px-2 py-1 bg-green-100 text-green-700 rounded-full text-sm">
                                <i class="fas fa-check-circle"></i> Hoạt động
                            </span>
                        }
                        else
                        {
                            <span class="px-2 py-1 bg-red-100 text-red-700 rounded-full text-sm">
                                <i class="fas fa-ban"></i> Khóa
                            </span>
                        }
                    </div>
                </div>
            </div>

            <div class="flex justify-end space-x-3 pt-4 border-t">
                <a asp-action="Edit" asp-route-id="@Model.MaTaiKhoan" class="px-4 py-2 bg-yellow-500 text-white rounded-lg hover:bg-yellow-600 transition-all">
                    <i class="fas fa-edit mr-2"></i> Chỉnh sửa
                </a>
                <a asp-action="Delete" asp-route-id="@Model.MaTaiKhoan" class="px-4 py-2 bg-red-500 text-white rounded-lg hover:bg-red-600 transition-all">
                    <i class="fas fa-trash mr-2"></i> Xóa
                </a>
            </div>
        </div>
    </div>
</div>
