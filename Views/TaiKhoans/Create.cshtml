@model HeThongQuanLyPhongTro.Models.TaiKhoan

@{
    ViewData["Title"] = "Thêm tài khoản";
    var khachHang = ViewBag.KhachHangList as List<HeThongQuanLyPhongTro.Models.KhachHang>;
    var phongList = ViewBag.PhongList as List<HeThongQuanLyPhongTro.Models.Phong>;
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-gray-100">

    <div class="container mx-auto px-4 py-8">
        <div class="max-w-2xl mx-auto">
            <div class="bg-white rounded-xl shadow-md overflow-hidden">
                <div class="bg-gradient-to-r from-blue-500 to-blue-600 px-6 py-4">
                    <h1 class="text-xl font-bold text-white">Thêm tài khoản mới</h1>
                    <p class="text-blue-100 text-sm">Tạo tài khoản và gắn với khách hàng/phòng</p>
                </div>

                <form asp-action="Create" method="post" class="p-6 space-y-4">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="bg-red-100 text-red-700 p-3 rounded-lg text-sm"></div>

                    <!-- Tên đăng nhập -->
                    <div>
                        <label asp-for="TenDangNhap" class="block text-sm font-medium text-gray-700 mb-2">Tên đăng nhập <span class="text-red-500">*</span></label>
                        <input asp-for="TenDangNhap" class="w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" />
                        <span asp-validation-for="TenDangNhap" class="text-red-500 text-sm"></span>
                    </div>

                    <!-- Mật khẩu -->
                    <div>
                        <label asp-for="MatKhau" class="block text-sm font-medium text-gray-700 mb-2">Mật khẩu <span class="text-red-500">*</span></label>
                        <input asp-for="MatKhau" type="password" class="w-full px-3 py-2 border rounded-lg" />
                        <span asp-validation-for="MatKhau" class="text-red-500 text-sm"></span>
                    </div>

                    <!-- Vai trò -->
                    <div>
                        <label asp-for="VaiTro" class="block text-sm font-medium text-gray-700 mb-2">Vai trò</label>
                        <select asp-for="VaiTro" id="VaiTro" class="w-full px-3 py-2 border rounded-lg">
                            <option value="Admin">Admin</option>
                            <option value="Khach">Khách hàng</option>
                        </select>
                    </div>

                    <!-- Khu vực chọn khách hàng (chỉ hiện khi chọn Khách) -->
                    <div id="khachHangSection" style="display: none;">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Chọn khách hàng</label>
                            <select id="MaKhachHang" name="MaKhachHang" class="w-full px-3 py-2 border rounded-lg">
                                <option value="">-- Chọn khách hàng --</option>
                                @if (khachHang != null)
                                {
                                    @foreach (var kh in khachHang)
                                    {
                                        <option value="@kh.MaKhachHang">@kh.HoTen - @kh.SoDienThoai</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="mt-2">
                            <label class="block text-sm font-medium text-gray-700 mb-2">Chọn phòng cho khách</label>
                            <select id="MaPhong" name="MaPhong" class="w-full px-3 py-2 border rounded-lg">
                                <option value="">-- Chọn phòng trống --</option>
                                @if (phongList != null)
                                {
                                    @foreach (var p in phongList.Where(p => p.TrangThai == "Trống"))
                                    {
                                        <option value="@p.MaPhong">@p.TenPhong - @p.CoSo?.TenCoSo - @p.GiaPhong.ToString("N0") đ</option>
                                    }
                                }
                            </select>
                            <p class="text-xs text-gray-500 mt-1">Chọn phòng trống để gắn cho khách này</p>
                        </div>
                    </div>

                    <div class="bg-yellow-50 rounded-lg p-4">
                        <p class="text-sm text-yellow-700">
                            <i class="fas fa-info-circle mr-2"></i>
                            Nếu chọn "Khách hàng", bạn cần chọn khách hàng và phòng tương ứng.
                        </p>
                    </div>

                    <div class="flex justify-end space-x-3 pt-4">
                        <a asp-action="Index" class="px-4 py-2 border rounded-lg">Hủy</a>
                        <button type="submit" class="px-4 py-2 bg-blue-500 text-white rounded-lg">Tạo tài khoản</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        // Hiển thị/ẩn phần chọn khách hàng
        document.getElementById('VaiTro').addEventListener('change', function() {
            var khachSection = document.getElementById('khachHangSection');
            if (this.value === 'Khach') {
                khachSection.style.display = 'block';
            } else {
                khachSection.style.display = 'none';
            }
        });
    </script>

</body>
</html>