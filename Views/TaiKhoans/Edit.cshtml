@model IEnumerable<HeThongQuanLyPhongTro.Models.TaiKhoan>

@{
    ViewData["Title"] = "Quản lý tài khoản";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-gray-100">

    <div class="container mx-auto px-4 py-8">
        <div class="bg-white rounded-xl shadow-md overflow-hidden">
            <!-- Header -->
            <div class="bg-gradient-to-r from-blue-500 to-blue-600 px-6 py-4 flex justify-between items-center">
                <div>
                    <h1 class="text-xl font-bold text-white">Quản lý tài khoản</h1>
                    <p class="text-blue-100 text-sm">Danh sách tài khoản đăng nhập hệ thống</p>
                </div>
                <a asp-action="Create" class="bg-white text-blue-600 px-4 py-2 rounded-lg hover:bg-blue-50 transition-all">
                    <i class="fas fa-plus mr-2"></i> Thêm tài khoản
                </a>
            </div>

            <div class="p-6">
                <div class="overflow-x-auto">
                    <table class="w-full">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500">Mã</th>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500">Tên đăng nhập</th>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500">Vai trò</th>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500">Trạng thái</th>
                                <th class="px-4 py-3 text-center text-xs font-medium text-gray-500">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-200">
                            @foreach (var item in Model)
                            {
                                <tr class="hover:bg-gray-50">
                                    <td class="px-4 py-3">@item.MaTaiKhoan</td>
                                    <td class="px-4 py-3 font-medium">@item.TenDangNhap</td>
                                    <td class="px-4 py-3">
                                        @if (item.VaiTro == "Admin")
                                        {
                                            <span class="px-2 py-1 bg-purple-100 text-purple-700 rounded-full text-xs">
                                                <i class="fas fa-crown"></i> Admin
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="px-2 py-1 bg-blue-100 text-blue-700 rounded-full text-xs">
                                                <i class="fas fa-user"></i> Khách
                                            </span>
                                        }
                                    </td>
                                    <td class="px-4 py-3">
                                        @if (item.TrangThai == "Hoạt động")
                                        {
                                            <span class="px-2 py-1 bg-green-100 text-green-700 rounded-full text-xs">
                                                <i class="fas fa-check-circle"></i> Hoạt động
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="px-2 py-1 bg-red-100 text-red-700 rounded-full text-xs">
                                                <i class="fas fa-ban"></i> Khóa
                                            </span>
                                        }
                                    </td>
                                    <td class="px-4 py-3 text-center">
                                        <a asp-action="Details" asp-route-id="@item.MaTaiKhoan" class="text-blue-500 hover:text-blue-700 mx-1" title="Chi tiết">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.MaTaiKhoan" class="text-yellow-500 hover:text-yellow-700 mx-1" title="Sửa">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.MaTaiKhoan" class="text-red-500 hover:text-red-700 mx-1" title="Xóa">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (!Model.Any())
                {
                    <div class="text-center py-12">
                        <i class="fas fa-users text-gray-300 text-5xl mb-3"></i>
                        <p class="text-gray-500">Chưa có tài khoản nào</p>
                        <a asp-action="Create" class="inline-block mt-3 text-blue-500 hover:underline">Thêm tài khoản đầu tiên</a>
                    </div>
                }
            </div>
        </div>
    </div>

</body>
</html>