@model IEnumerable<HeThongQuanLyPhongTro.Models.NguoiOHopDong>

@{
    ViewData["Title"] = "Quản lý người ở";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-gray-100">

    <div class="container mx-auto px-4 py-8">
        <div class="bg-white rounded-xl shadow-md overflow-hidden">
            <div class="bg-gradient-to-r from-blue-500 to-blue-600 px-6 py-4 flex justify-between items-center">
                <div>
                    <h1 class="text-xl font-bold text-white">Quản lý người ở</h1>
                    <p class="text-blue-100 text-sm">Danh sách người ở trong các hợp đồng</p>
                </div>
                <a asp-action="Create" class="bg-white text-blue-600 px-4 py-2 rounded-lg hover:bg-blue-50 transition-all">
                    <i class="fas fa-plus mr-2"></i> Thêm mới
                </a>
            </div>

            <div class="p-6">
                <div class="overflow-x-auto">
                    <table class="w-full">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500">Mã</th>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500">Hợp đồng</th>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500">Họ tên</th>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500">CCCD</th>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500">SĐT</th>
                                <th class="px-4 py-3 text-center text-xs font-medium text-gray-500">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-200">
                            @foreach (var item in Model)
                            {
                                <tr class="hover:bg-gray-50">
                                    <td class="px-4 py-3">@item.MaNguoiO</td>
                                    <td class="px-4 py-3">@item.HopDongNavigation?.MaHopDong</td>
                                    <td class="px-4 py-3 font-medium">@item.HoTen</td>
                                    <td class="px-4 py-3">@item.CCCD</td>
                                    <td class="px-4 py-3">@item.SoDienThoai</td>
                                    <td class="px-4 py-3 text-center">
                                        <a asp-action="Details" asp-route-id="@item.MaNguoiO" class="text-blue-500 hover:text-blue-700 mx-1">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.MaNguoiO" class="text-yellow-500 hover:text-yellow-700 mx-1">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.MaNguoiO" class="text-red-500 hover:text-red-700 mx-1">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (!Model.Any())
                {
                    <div class="text-center py-12">
                        <i class="fas fa-users text-gray-300 text-5xl mb-3"></i>
                        <p class="text-gray-500">Chưa có người ở nào</p>
                        <a asp-action="Create" class="inline-block mt-3 text-blue-500 hover:underline">Thêm người ở đầu tiên</a>
                    </div>
                }
            </div>
        </div>
    </div>

</body>
</html>