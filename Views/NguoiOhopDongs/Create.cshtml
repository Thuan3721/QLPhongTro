@model HeThongQuanLyPhongTro.Models.NguoiOHopDong

@{
    ViewData["Title"] = "Thêm người ở";
    var khachHangList = ViewBag.KhachHangList as List<HeThongQuanLyPhongTro.Models.KhachHang>;
}

<div class="max-w-2xl mx-auto">
    <div class="bg-white rounded-xl shadow-md overflow-hidden">
        <div class="bg-gradient-to-r from-blue-500 to-blue-600 px-6 py-4">
            <h1 class="text-xl font-bold text-white">Thêm người ở</h1>
            <p class="text-blue-100">Thêm người ở cho khách hàng (chuẩn bị tạo hợp đồng)</p>
        </div>

        <form asp-action="Create" class="p-6 space-y-4">
            <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm"></div>

            <div>
                <label asp-for="MaKhachHang" class="block text-sm font-medium text-gray-700 mb-2">Chọn khách hàng (người đại diện)</label>
                <select asp-for="MaKhachHang" class="w-full px-3 py-2 border rounded-lg" required>
                    <option value="">-- Chọn khách hàng --</option>
                    @foreach (var kh in khachHangList ?? new List<HeThongQuanLyPhongTro.Models.KhachHang>())
                    {
                        <option value="@kh.MaKhachHang">@kh.HoTen - @kh.SoDienThoai</option>
                    }
                </select>
                <span asp-validation-for="MaKhachHang" class="text-red-500 text-sm"></span>
            </div>

            <div>
                <label asp-for="HoTen" class="block text-sm font-medium text-gray-700 mb-2">Họ tên</label>
                <input asp-for="HoTen" class="w-full px-3 py-2 border rounded-lg" />
                <span asp-validation-for="HoTen" class="text-red-500 text-sm"></span>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label asp-for="CCCD" class="block text-sm font-medium text-gray-700 mb-2">CCCD/CMND</label>
                    <input asp-for="CCCD" class="w-full px-3 py-2 border rounded-lg" />
                    <span asp-validation-for="CCCD" class="text-red-500 text-sm"></span>
                </div>
                <div>
                    <label asp-for="SoDienThoai" class="block text-sm font-medium text-gray-700 mb-2">Số điện thoại</label>
                    <input asp-for="SoDienThoai" class="w-full px-3 py-2 border rounded-lg" />
                    <span asp-validation-for="SoDienThoai" class="text-red-500 text-sm"></span>
                </div>
            </div>

            <div class="flex items-center">
                <input asp-for="LaNguoiDaiDien" type="checkbox" class="w-4 h-4 text-blue-500" />
                <label asp-for="LaNguoiDaiDien" class="ml-2 text-sm text-gray-700">Là người đại diện</label>
            </div>

            <div class="flex justify-end space-x-3 pt-4">
                <a asp-action="Index" class="px-4 py-2 border rounded-lg">Hủy</a>
                <button type="submit" class="px-4 py-2 bg-blue-500 text-white rounded-lg">
                    <i class="fas fa-save mr-2"></i> Lưu
                </button>
            </div>
        </form>
    </div>
</div>