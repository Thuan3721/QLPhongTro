@model HeThongQuanLyPhongTro.Models.NguoiOHopDong

@{
    ViewData["Title"] = "Thêm người ở";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-gray-100">

    <div class="container mx-auto px-4 py-8">
        <div class="max-w-2xl mx-auto">
            <div class="bg-white rounded-xl shadow-md overflow-hidden">
                <!-- Header -->
                <div class="bg-gradient-to-r from-blue-500 to-blue-600 px-6 py-4">
                    <div class="flex justify-between items-center">
                        <div>
                            <h1 class="text-xl font-bold text-white">Thêm người ở</h1>
                            <p class="text-blue-100 text-sm">Nhập thông tin người ở trong hợp đồng</p>
                        </div>
                        <a asp-action="Index" class="text-white hover:text-blue-200 transition-all">
                            <i class="fas fa-arrow-left mr-2"></i> Quay lại
                        </a>
                    </div>
                </div>

                <!-- Form -->
                <form asp-action="Create" class="p-6 space-y-4">
                    <div asp-validation-summary="ModelOnly" class="bg-red-100 text-red-700 p-3 rounded-lg text-sm"></div>

                    <div>
                        <label asp-for="MaHopDong" class="block text-sm font-medium text-gray-700 mb-2">Hợp đồng <span class="text-red-500">*</span></label>
                        <select asp-for="MaHopDong" class="w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" asp-items="ViewBag.MaHopDong">
                            <option value="">-- Chọn hợp đồng --</option>
                        </select>
                        <span asp-validation-for="MaHopDong" class="text-red-500 text-sm"></span>
                    </div>

                    <div>
                        <label asp-for="HoTen" class="block text-sm font-medium text-gray-700 mb-2">Họ tên <span class="text-red-500">*</span></label>
                        <input asp-for="HoTen" class="w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="Nhập họ tên đầy đủ" />
                        <span asp-validation-for="HoTen" class="text-red-500 text-sm"></span>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label asp-for="CCCD" class="block text-sm font-medium text-gray-700 mb-2">CCCD/CMND</label>
                            <input asp-for="CCCD" class="w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="Nhập số CCCD" />
                            <span asp-validation-for="CCCD" class="text-red-500 text-sm"></span>
                        </div>

                        <div>
                            <label asp-for="SoDienThoai" class="block text-sm font-medium text-gray-700 mb-2">Số điện thoại</label>
                            <input asp-for="SoDienThoai" class="w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="Nhập số điện thoại" />
                            <span asp-validation-for="SoDienThoai" class="text-red-500 text-sm"></span>
                        </div>
                    </div>

                    <div class="bg-yellow-50 rounded-lg p-4">
                        <div class="flex items-start">
                            <i class="fas fa-info-circle text-yellow-500 mt-1 mr-3"></i>
                            <div class="text-sm text-yellow-700">
                                <p class="font-semibold">Lưu ý:</p>
                                <ul class="list-disc list-inside mt-1">
                                    <li>Chọn hợp đồng tương ứng với người ở</li>
                                    <li>Có thể thêm nhiều người ở cho một hợp đồng</li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <div class="flex justify-end space-x-3 pt-4">
                        <a asp-action="Index" class="px-4 py-2 border rounded-lg hover:bg-gray-50 transition-all">Hủy</a>
                        <button type="submit" class="px-4 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600 transition-all">
                            <i class="fas fa-save mr-2"></i> Lưu
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

</body>
</html>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}