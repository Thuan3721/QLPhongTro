@model HeThongQuanLyPhongTro.Models.NguoiOHopDong

@{
    ViewData["Title"] = "Chỉnh sửa người ở";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-gray-100">

    <div class="container mx-auto px-4 py-8">
        <div class="max-w-2xl mx-auto">
            <div class="bg-white rounded-xl shadow-md overflow-hidden">
                <!-- Header -->
                <div class="bg-gradient-to-r from-yellow-500 to-yellow-600 px-6 py-4">
                    <div class="flex justify-between items-center">
                        <div>
                            <h1 class="text-xl font-bold text-white">Chỉnh sửa người ở</h1>
                            <p class="text-yellow-100 text-sm">Cập nhật thông tin người ở</p>
                        </div>
                        <a asp-action="Index" class="text-white hover:text-yellow-200 transition-all">
                            <i class="fas fa-arrow-left mr-2"></i> Quay lại
                        </a>
                    </div>
                </div>

                <!-- Form -->
                <form asp-action="Edit" class="p-6 space-y-4">
                    <div asp-validation-summary="ModelOnly" class="bg-red-100 text-red-700 p-3 rounded-lg text-sm"></div>
                    <input type="hidden" asp-for="MaNguoiO" />

                    <div>
                        <label asp-for="MaHopDong" class="block text-sm font-medium text-gray-700 mb-2">Hợp đồng <span class="text-red-500">*</span></label>
                        <select asp-for="MaHopDong" class="w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-yellow-500" asp-items="ViewBag.MaHopDong">
                            <option value="">-- Chọn hợp đồng --</option>
                        </select>
                        <span asp-validation-for="MaHopDong" class="text-red-500 text-sm"></span>
                    </div>

                    <div>
                        <label asp-for="HoTen" class="block text-sm font-medium text-gray-700 mb-2">Họ tên <span class="text-red-500">*</span></label>
                        <input asp-for="HoTen" class="w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-yellow-500" />
                        <span asp-validation-for="HoTen" class="text-red-500 text-sm"></span>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label asp-for="CCCD" class="block text-sm font-medium text-gray-700 mb-2">CCCD/CMND</label>
                            <input asp-for="CCCD" class="w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-yellow-500" />
                            <span asp-validation-for="CCCD" class="text-red-500 text-sm"></span>
                        </div>

                        <div>
                            <label asp-for="SoDienThoai" class="block text-sm font-medium text-gray-700 mb-2">Số điện thoại</label>
                            <input asp-for="SoDienThoai" class="w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-yellow-500" />
                            <span asp-validation-for="SoDienThoai" class="text-red-500 text-sm"></span>
                        </div>
                    </div>

                    <div class="flex items-center">
                        <input asp-for="LaNguoiDaiDien" type="checkbox" class="w-4 h-4 text-yellow-500 focus:ring-yellow-500 border-gray-300 rounded" />
                        <label asp-for="LaNguoiDaiDien" class="ml-2 text-sm text-gray-700">Là người đại diện</label>
                    </div>

                    <div class="flex justify-end space-x-3 pt-4">
                        <a asp-action="Index" class="px-4 py-2 border rounded-lg hover:bg-gray-50 transition-all">Hủy</a>
                        <button type="submit" class="px-4 py-2 bg-yellow-500 text-white rounded-lg hover:bg-yellow-600 transition-all">
                            <i class="fas fa-save mr-2"></i> Cập nhật
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

</body>
</html>