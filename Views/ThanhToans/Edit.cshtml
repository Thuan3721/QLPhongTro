@model HeThongQuanLyPhongTro.Models.ThanhToan

@{
    ViewData["Title"] = "Chỉnh sửa thanh toán";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-gray-100">

    <div class="container mx-auto px-4 py-8">
        <div class="max-w-2xl mx-auto">
            <div class="bg-white rounded-xl shadow-md overflow-hidden">
                <!-- Header -->
                <div class="bg-gradient-to-r from-yellow-500 to-yellow-600 px-6 py-4">
                    <div class="flex justify-between items-center">
                        <div>
                            <h1 class="text-xl font-bold text-white">Chỉnh sửa thanh toán</h1>
                            <p class="text-yellow-100 text-sm">Mã thanh toán: @Model.MaThanhToan</p>
                        </div>
                        <a asp-action="Index" class="text-white hover:text-yellow-200 transition-all">
                            <i class="fas fa-arrow-left mr-2"></i> Quay lại
                        </a>
                    </div>
                </div>

                <!-- Form -->
                <form asp-action="Edit" class="p-6 space-y-4">
                    <div asp-validation-summary="ModelOnly" class="bg-red-100 text-red-700 p-3 rounded-lg text-sm"></div>
                    <input type="hidden" asp-for="MaThanhToan" />

                    <div>
                        <label asp-for="MaHoaDon" class="block text-sm font-medium text-gray-700 mb-2">Hóa đơn <span class="text-red-500">*</span></label>
                        <select asp-for="MaHoaDon" class="w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-yellow-500" asp-items="ViewBag.MaHoaDon">
                            <option value="">-- Chọn hóa đơn --</option>
                        </select>
                        <span asp-validation-for="MaHoaDon" class="text-red-500 text-sm"></span>
                    </div>

                    <div>
                        <label asp-for="SoTien" class="block text-sm font-medium text-gray-700 mb-2">Số tiền <span class="text-red-500">*</span></label>
                        <input asp-for="SoTien" type="number" class="w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-yellow-500" placeholder="Nhập số tiền" />
                        <span asp-validation-for="SoTien" class="text-red-500 text-sm"></span>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label asp-for="NgayThanhToan" class="block text-sm font-medium text-gray-700 mb-2">Ngày thanh toán</label>
                            <input asp-for="NgayThanhToan" type="datetime-local" class="w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-yellow-500" />
                            <span asp-validation-for="NgayThanhToan" class="text-red-500 text-sm"></span>
                        </div>

                        <div>
                            <label asp-for="TrangThai" class="block text-sm font-medium text-gray-700 mb-2">Trạng thái</label>
                            <select asp-for="TrangThai" class="w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-yellow-500">
                                <option value="Thành công">Thành công</option>
                                <option value="Đang xử lý">Đang xử lý</option>
                                <option value="Thất bại">Thất bại</option>
                            </select>
                            <span asp-validation-for="TrangThai" class="text-red-500 text-sm"></span>
                        </div>
                    </div>

                    <div>
                        <label asp-for="NoiDungChuyenKhoan" class="block text-sm font-medium text-gray-700 mb-2">Nội dung chuyển khoản</label>
                        <input asp-for="NoiDungChuyenKhoan" class="w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-yellow-500" placeholder="Nhập nội dung" />
                        <span asp-validation-for="NoiDungChuyenKhoan" class="text-red-500 text-sm"></span>
                    </div>

                    <div class="flex justify-end space-x-3 pt-4">
                        <a asp-action="Index" class="px-4 py-2 border rounded-lg hover:bg-gray-50 transition-all">Hủy</a>
                        <button type="submit" class="px-4 py-2 bg-yellow-500 text-white rounded-lg hover:bg-yellow-600 transition-all">
                            <i class="fas fa-save mr-2"></i> Cập nhật
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

</body>
</html>