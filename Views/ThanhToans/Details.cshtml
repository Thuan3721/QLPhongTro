@model HeThongQuanLyPhongTro.Models.ThanhToan

@{
    ViewData["Title"] = "Chi tiết thanh toán";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-gray-100">

    <div class="container mx-auto px-4 py-8">
        <div class="max-w-2xl mx-auto">
            <div class="bg-white rounded-xl shadow-md overflow-hidden">
                <!-- Header -->
                <div class="bg-gradient-to-r from-purple-500 to-purple-600 px-6 py-4">
                    <div class="flex justify-between items-center">
                        <div>
                            <h1 class="text-xl font-bold text-white">Chi tiết thanh toán</h1>
                            <p class="text-purple-100 text-sm">Mã thanh toán: @Model.MaThanhToan</p>
                        </div>
                        <a asp-action="Index" class="text-white hover:text-purple-200 transition-all">
                            <i class="fas fa-arrow-left mr-2"></i> Quay lại
                        </a>
                    </div>
                </div>

                <div class="p-6">
                    <div class="bg-gray-50 rounded-lg p-5 mb-6">
                        <h3 class="font-semibold text-gray-700 mb-3 flex items-center">
                            <i class="fas fa-info-circle text-purple-500 mr-2"></i>
                            Thông tin thanh toán
                        </h3>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <p class="text-gray-500 text-sm">Mã thanh toán</p>
                                <p class="font-semibold">@Model.MaThanhToan</p>
                            </div>
                            <div>
                                <p class="text-gray-500 text-sm">Mã hóa đơn</p>
                                <p class="font-semibold text-blue-600">HD@(Model.HoaDonNavigation?.MaHoaDon)</p>
                            </div>
                            <div>
                                <p class="text-gray-500 text-sm">Số tiền</p>
                                <p class="text-2xl font-bold text-green-600">@(Model.SoTien?.ToString("N0") ?? "0") đ</p>
                            </div>
                            <div>
                                <p class="text-gray-500 text-sm">Ngày thanh toán</p>
                                <p class="font-semibold">@(Model.NgayThanhToan?.ToString("dd/MM/yyyy HH:mm") ?? "N/A")</p>
                            </div>
                            <div>
                                <p class="text-gray-500 text-sm">Nội dung</p>
                                <p class="font-semibold">@(Model.NoiDungChuyenKhoan ?? "Không có nội dung")</p>
                            </div>
                            <div>
                                <p class="text-gray-500 text-sm">Trạng thái</p>
                                @if (Model.TrangThai == "Thành công")
                                {
                                    <span class="px-2 py-1 bg-green-100 text-green-700 rounded-full text-sm">
                                        <i class="fas fa-check-circle"></i> Thành công
                                    </span>
                                }
                                else if (Model.TrangThai == "Đang xử lý")
                                {
                                    <span class="px-2 py-1 bg-yellow-100 text-yellow-700 rounded-full text-sm">
                                        <i class="fas fa-spinner"></i> Đang xử lý
                                    </span>
                                }
                                else
                                {
                                    <span class="px-2 py-1 bg-red-100 text-red-700 rounded-full text-sm">
                                        @Model.TrangThai
                                    </span>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="flex justify-end space-x-3 pt-4 border-t">
                        <a asp-action="Edit" asp-route-id="@Model.MaThanhToan" class="px-4 py-2 bg-yellow-500 text-white rounded-lg hover:bg-yellow-600 transition-all">
                            <i class="fas fa-edit mr-2"></i> Chỉnh sửa
                        </a>
                        <a asp-action="Delete" asp-route-id="@Model.MaThanhToan" class="px-4 py-2 bg-red-500 text-white rounded-lg hover:bg-red-600 transition-all">
                            <i class="fas fa-trash mr-2"></i> Xóa
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

</body>
</html>