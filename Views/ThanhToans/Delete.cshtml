@model HeThongQuanLyPhongTro.Models.ThanhToan

@{
    ViewData["Title"] = "Xóa thanh toán";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-gray-100">

    <div class="container mx-auto px-4 py-8">
        <div class="max-w-2xl mx-auto">
            <div class="bg-white rounded-xl shadow-md overflow-hidden">
                <!-- Header -->
                <div class="bg-gradient-to-r from-red-500 to-red-600 px-6 py-4">
                    <div class="flex justify-between items-center">
                        <div>
                            <h1 class="text-xl font-bold text-white">Xóa thanh toán</h1>
                            <p class="text-red-100 text-sm">Mã thanh toán: @Model.MaThanhToan</p>
                        </div>
                        <a asp-action="Index" class="text-white hover:text-red-200 transition-all">
                            <i class="fas fa-arrow-left mr-2"></i> Quay lại
                        </a>
                    </div>
                </div>

                <div class="p-6">
                    <!-- Cảnh báo -->
                    <div class="bg-yellow-50 border-l-4 border-yellow-400 p-4 mb-6">
                        <div class="flex items-center">
                            <i class="fas fa-exclamation-triangle text-yellow-400 text-xl mr-3"></i>
                            <div>
                                <p class="text-yellow-700 font-semibold">Bạn có chắc chắn muốn xóa giao dịch thanh toán này?</p>
                                <p class="text-yellow-600 text-sm">Hành động này không thể khôi phục!</p>
                            </div>
                        </div>
                    </div>

                    <!-- Thông tin thanh toán -->
                    <div class="bg-gray-50 rounded-lg p-5 mb-6">
                        <h3 class="font-semibold text-gray-700 mb-3 flex items-center">
                            <i class="fas fa-money-bill-wave text-red-500 mr-2"></i>
                            Thông tin thanh toán
                        </h3>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <p class="text-gray-500 text-sm">Mã thanh toán</p>
                                <p class="font-semibold">TT@Model.MaThanhToan</p>
                            </div>
                            <div>
                                <p class="text-gray-500 text-sm">Mã hóa đơn</p>
                                <p class="font-semibold">HD@(Model.HoaDonNavigation?.MaHoaDon)</p>
                            </div>
                            <div>
                                <p class="text-gray-500 text-sm">Số tiền</p>
                                <p class="text-2xl font-bold text-blue-600">@(Model.SoTien?.ToString("N0") ?? "0") đ</p>
                            </div>
                            <div>
                                <p class="text-gray-500 text-sm">Ngày thanh toán</p>
                                <p class="font-semibold">@(Model.NgayThanhToan?.ToString("dd/MM/yyyy HH:mm") ?? "N/A")</p>
                            </div>
                            <div>
                                <p class="text-gray-500 text-sm">Nội dung</p>
                                <p class="font-semibold">@(Model.NoiDungChuyenKhoan ?? "Không có")</p>
                            </div>
                            <div>
                                <p class="text-gray-500 text-sm">Trạng thái</p>
                                @if (Model.TrangThai == "Thành công")
                                {
                                    <span class="px-2 py-1 bg-green-100 text-green-700 rounded-full text-xs">
                                        <i class="fas fa-check-circle"></i> Thành công
                                    </span>
                                }
                                else
                                {
                                    <span class="px-2 py-1 bg-gray-100 text-gray-600 rounded-full text-xs">@Model.TrangThai</span>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- Form xác nhận xóa -->
                    <form asp-action="Delete" class="flex justify-end space-x-3">
                        <input type="hidden" name="id" value="@Model.MaThanhToan" />
                        <a asp-action="Index" class="px-4 py-2 border rounded-lg hover:bg-gray-50 transition-all">Hủy</a>
                        <button type="submit" class="px-4 py-2 bg-red-500 text-white rounded-lg hover:bg-red-600 transition-all">
                            <i class="fas fa-trash mr-2"></i> Xóa
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

</body>
</html>