@model IEnumerable<HeThongQuanLyPhongTro.Models.ThanhToan>

@{
    ViewData["Title"] = "Quản lý thanh toán";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-gray-100">

    <div class="container mx-auto px-4 py-8">
        <div class="bg-white rounded-xl shadow-md overflow-hidden">
            <div class="bg-gradient-to-r from-blue-500 to-blue-600 px-6 py-4 flex justify-between items-center">
                <div>
                    <h1 class="text-xl font-bold text-white">Quản lý thanh toán</h1>
                    <p class="text-blue-100 text-sm">Danh sách giao dịch thanh toán</p>
                </div>
                <a asp-action="Create" class="bg-white text-blue-600 px-4 py-2 rounded-lg hover:bg-blue-50 transition-all">
                    <i class="fas fa-plus mr-2"></i> Thêm thanh toán
                </a>
            </div>

            <div class="p-6">
                <div class="overflow-x-auto">
                    <table class="w-full">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500">Mã TT</th>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500">Hóa đơn</th>
                                <th class="px-4 py-3 text-right text-xs font-medium text-gray-500">Số tiền</th>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500">Ngày thanh toán</th>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500">Nội dung</th>
                                <th class="px-4 py-3 text-center text-xs font-medium text-gray-500">Thao tác</th>
                    </table>
                    </thead>
                    <tbody class="divide-y divide-gray-200">
                        @foreach (var item in Model)
                        {
                            <tr class="hover:bg-gray-50">
                                <td class="px-4 py-3 font-medium">@item.MaThanhToan</td>
                                <td class="px-4 py-3">HD@(item.HoaDonNavigation?.MaHoaDon)</td>
                                <td class="px-4 py-3 text-right font-semibold text-green-600">@(item.SoTien?.ToString("N0") ?? "0") đ</td>
                                <td class="px-4 py-3">@(item.NgayThanhToan?.ToString("dd/MM/yyyy HH:mm") ?? "N/A")</td>
                                <td class="px-4 py-3">@(item.NoiDungChuyenKhoan ?? "---")</td>
                                <td class="px-4 py-3 text-center">
                                    <a asp-action="Details" asp-route-id="@item.MaThanhToan" class="text-blue-500 hover:text-blue-700 mx-1"><i class="fas fa-eye"></i></a>
                                    <a asp-action="Edit" asp-route-id="@item.MaThanhToan" class="text-yellow-500 hover:text-yellow-700 mx-1"><i class="fas fa-edit"></i></a>
                                    <a asp-action="Delete" asp-route-id="@item.MaThanhToan" class="text-red-500 hover:text-red-700 mx-1"><i class="fas fa-trash"></i></a>
                                </td>
                            </tr>
                        }
                    </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

</body>
</html>