@model HeThongQuanLyPhongTro.Models.ChiTietHoaDon

@{
    ViewData["Title"] = "Thêm khoản thu";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-gray-100">

    <div class="container mx-auto px-4 py-8">
        <div class="max-w-2xl mx-auto">
            <div class="bg-white rounded-xl shadow-md overflow-hidden">
                <!-- Header -->
                <div class="bg-gradient-to-r from-blue-500 to-blue-600 px-6 py-4">
                    <div class="flex justify-between items-center">
                        <div>
                            <h1 class="text-xl font-bold text-white">Thêm khoản thu</h1>
                            <p class="text-blue-100 text-sm">Thêm chi tiết khoản thu cho hóa đơn</p>
                        </div>
                        <a asp-action="Index" class="text-white hover:text-blue-200 transition-all">
                            <i class="fas fa-arrow-left mr-2"></i> Quay lại
                        </a>
                    </div>
                </div>

                <!-- Form -->
                <form asp-action="Create" class="p-6 space-y-4">
                    <div asp-validation-summary="ModelOnly" class="bg-red-100 text-red-700 p-3 rounded-lg text-sm"></div>

                    <div>
                        <label asp-for="MaHoaDon" class="block text-sm font-medium text-gray-700 mb-2">Hóa đơn <span class="text-red-500">*</span></label>
                        <select asp-for="MaHoaDon" class="w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" asp-items="ViewBag.MaHoaDon">
                            <option value="">-- Chọn hóa đơn --</option>
                        </select>
                        <span asp-validation-for="MaHoaDon" class="text-red-500 text-sm"></span>
                    </div>

                    <div>
                        <label asp-for="LoaiKhoanThu" class="block text-sm font-medium text-gray-700 mb-2">Loại khoản thu <span class="text-red-500">*</span></label>
                        <select asp-for="LoaiKhoanThu" class="w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
                            <option value="">-- Chọn loại --</option>
                            <option value="Tiền phòng">Tiền phòng</option>
                            <option value="Tiền điện">Tiền điện</option>
                            <option value="Tiền nước">Tiền nước</option>
                            <option value="Tiền rác">Tiền rác</option>
                            <option value="Tiền wifi">Tiền wifi</option>
                            <option value="Phí dịch vụ">Phí dịch vụ</option>
                            <option value="Phí phát sinh">Phí phát sinh</option>
                        </select>
                        <span asp-validation-for="LoaiKhoanThu" class="text-red-500 text-sm"></span>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label asp-for="SoLuong" class="block text-sm font-medium text-gray-700 mb-2">Số lượng</label>
                            <input asp-for="SoLuong" type="number" step="0.01" class="w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="1" value="1" />
                            <span asp-validation-for="SoLuong" class="text-red-500 text-sm"></span>
                        </div>

                        <div>
                            <label asp-for="DonGia" class="block text-sm font-medium text-gray-700 mb-2">Đơn giá (VNĐ)</label>
                            <input asp-for="DonGia" type="number" class="w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="0" />
                            <span asp-validation-for="DonGia" class="text-red-500 text-sm"></span>
                        </div>
                    </div>

                    <div>
                        <label asp-for="GhiChu" class="block text-sm font-medium text-gray-700 mb-2">Ghi chú</label>
                        <textarea asp-for="GhiChu" rows="2" class="w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="Nhập ghi chú (nếu có)"></textarea>
                        <span asp-validation-for="GhiChu" class="text-red-500 text-sm"></span>
                    </div>

                    <div class="bg-yellow-50 rounded-lg p-4">
                        <div class="flex items-start">
                            <i class="fas fa-calculator text-yellow-500 mt-1 mr-3"></i>
                            <div class="text-sm text-yellow-700">
                                <p class="font-semibold">Thành tiền = Số lượng × Đơn giá</p>
                                <p class="text-xs mt-1">Hệ thống sẽ tự động tính thành tiền</p>
                            </div>
                        </div>
                    </div>

                    <div class="flex justify-end space-x-3 pt-4">
                        <a asp-action="Index" class="px-4 py-2 border rounded-lg hover:bg-gray-50 transition-all">Hủy</a>
                        <button type="submit" class="px-4 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600 transition-all">
                            <i class="fas fa-save mr-2"></i> Lưu
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

</body>
</html>