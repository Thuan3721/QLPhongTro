@model HeThongQuanLyPhongTro.Models.ChiTietHoaDon

@{
    ViewData["Title"] = "Chi tiết khoản thu";
}

<div class="max-w-2xl mx-auto">
    <div class="bg-white rounded-xl shadow-md overflow-hidden">
        <!-- Header -->
        <div class="bg-gradient-to-r from-purple-500 to-purple-600 px-6 py-4">
            <div class="flex justify-between items-center">
                <div>
                    <h1 class="text-xl font-bold text-white">Chi tiết khoản thu</h1>
                    <p class="text-purple-100 text-sm">Mã chi tiết: @Model.MaChiTiet</p>
                </div>
                <a asp-action="Index" class="text-white hover:text-purple-200 transition-all">
                    <i class="fas fa-arrow-left mr-2"></i> Quay lại
                </a>
            </div>
        </div>

        <div class="p-6">
            <div class="bg-gray-50 rounded-lg p-5 mb-6">
                <h3 class="font-semibold text-gray-700 mb-3 flex items-center">
                    <i class="fas fa-info-circle text-purple-500 mr-2"></i>
                    Thông tin khoản thu
                </h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <p class="text-gray-500 text-sm">Mã chi tiết</p>
                        <p class="font-semibold">@Model.MaChiTiet</p>
                    </div>
                    <div>
                        <p class="text-gray-500 text-sm">Hóa đơn</p>
                        <p class="font-semibold text-blue-600">HD@(Model.HoaDonNavigation?.MaHoaDon)</p>
                    </div>
                    <div>
                        <p class="text-gray-500 text-sm">Loại khoản thu</p>
                        <p class="font-semibold text-lg">@Model.LoaiKhoanThu</p>
                    </div>
                    <div>
                        <p class="text-gray-500 text-sm">Số lượng</p>
                        <p class="font-semibold">@(Model.SoLuong ?? 0)</p>
                    </div>
                    <div>
                        <p class="text-gray-500 text-sm">Đơn giá</p>
                        <p class="font-semibold">@(Model.DonGia?.ToString("N0") ?? "0") đ</p>
                    </div>
                    <div>
                        <p class="text-gray-500 text-sm">Thành tiền</p>
                        <p class="text-2xl font-bold text-blue-600">@(Model.ThanhTien?.ToString("N0") ?? "0") đ</p>
                    </div>
                    <div class="md:col-span-2">
                        <p class="text-gray-500 text-sm">Ghi chú</p>
                        <p class="font-semibold">@(Model.GhiChu ?? "Không có ghi chú")</p>
                    </div>
                </div>
            </div>

            <div class="flex justify-end space-x-3 pt-4 border-t">
                <a asp-action="Edit" asp-route-id="@Model.MaChiTiet" class="px-4 py-2 bg-yellow-500 text-white rounded-lg hover:bg-yellow-600 transition-all">
                    <i class="fas fa-edit mr-2"></i> Chỉnh sửa
                </a>
                <a asp-action="Delete" asp-route-id="@Model.MaChiTiet" class="px-4 py-2 bg-red-500 text-white rounded-lg hover:bg-red-600 transition-all">
                    <i class="fas fa-trash mr-2"></i> Xóa
                </a>
            </div>
        </div>
    </div>
</div>
