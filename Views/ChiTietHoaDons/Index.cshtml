@model IEnumerable<HeThongQuanLyPhongTro.Models.ChiTietHoaDon>

@{
    ViewData["Title"] = "Quản lý chi tiết hóa đơn";
}

<div class="container mx-auto px-4 py-8">
    <div class="bg-white rounded-xl shadow-md overflow-hidden">
        <!-- Header -->
        <div class="bg-gradient-to-r from-blue-500 to-blue-600 px-6 py-4 flex justify-between items-center">
            <div>
                <h1 class="text-xl font-bold text-white">Quản lý chi tiết hóa đơn</h1>
                <p class="text-blue-100 text-sm">Danh sách các khoản thu trong hóa đơn</p>
            </div>
            <a asp-action="Create" class="bg-white text-blue-600 px-4 py-2 rounded-lg hover:bg-blue-50 transition-all">
                <i class="fas fa-plus mr-2"></i> Thêm khoản thu
            </a>
        </div>

        <div class="p-6">
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500">Mã</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500">Hóa đơn</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500">Khoản thu</th>
                            <th class="px-4 py-3 text-center text-xs font-medium text-gray-500">Số lượng</th>
                            <th class="px-4 py-3 text-right text-xs font-medium text-gray-500">Đơn giá</th>
                            <th class="px-4 py-3 text-right text-xs font-medium text-gray-500">Thành tiền</th>
                            <th class="px-4 py-3 text-center text-xs font-medium text-gray-500">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200">
                        @foreach (var item in Model)
                        {
                            <tr class="hover:bg-gray-50 transition-all">
                                <td class="px-4 py-3">@item.MaChiTiet</td>
                                <td class="px-4 py-3 font-medium">HD@(item.HoaDonNavigation?.MaHoaDon)</td>
                                <td class="px-4 py-3">@item.LoaiKhoanThu</td>
                                <td class="px-4 py-3 text-center">@(item.SoLuong ?? 0)</td>
                                <td class="px-4 py-3 text-right">@(item.DonGia?.ToString("N0") ?? "0") đ</td>
                                <td class="px-4 py-3 text-right font-semibold text-blue-600">@(item.ThanhTien?.ToString("N0") ?? "0") đ</td>
                                <td class="px-4 py-3 text-center">
                                    <a asp-action="Details" asp-route-id="@item.MaChiTiet" class="text-blue-500 hover:text-blue-700 mx-1" title="Chi tiết">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.MaChiTiet" class="text-yellow-500 hover:text-yellow-700 mx-1" title="Sửa">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.MaChiTiet" class="text-red-500 hover:text-red-700 mx-1" title="Xóa">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (!Model.Any())
            {
                <div class="text-center py-12">
                    <i class="fas fa-receipt text-gray-300 text-5xl mb-3"></i>
                    <p class="text-gray-500">Chưa có chi tiết hóa đơn nào</p>
                    <a asp-action="Create" class="inline-block mt-3 text-blue-500 hover:underline">Thêm khoản thu đầu tiên</a>
                </div>
            }
        </div>
    </div>
</div>
