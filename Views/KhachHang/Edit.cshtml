@model HeThongQuanLyPhongTro.Models.KhachHang

@{
    ViewData["Title"] = "Chỉnh sửa khách hàng";
}

<div class="max-w-2xl mx-auto">
    <div class="bg-white rounded-xl shadow-md overflow-hidden">
        <div class="bg-gradient-to-r from-yellow-500 to-yellow-600 px-6 py-4">
            <div class="flex justify-between items-center">
                <div>
                    <h1 class="text-xl font-bold text-white">Chỉnh sửa khách hàng</h1>
                    <p class="text-yellow-100">Mã KH: @Model.MaKhachHang</p>
                </div>
                <a asp-action="Index" class="text-white hover:text-yellow-200">
                    <i class="fas fa-arrow-left mr-2"></i> Quay lại
                </a>
            </div>
        </div>

        <form asp-action="Edit" class="p-6 space-y-4">
            <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm"></div>
            <input type="hidden" asp-for="MaKhachHang" />
            <input type="hidden" asp-for="MaTaiKhoan" />

            <div>
                <label asp-for="HoTen" class="block text-sm font-medium text-gray-700 mb-2">Họ tên</label>
                <input asp-for="HoTen" class="w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-yellow-500" />
                <span asp-validation-for="HoTen" class="text-red-500 text-sm"></span>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label asp-for="SoDienThoai" class="block text-sm font-medium text-gray-700 mb-2">Số điện thoại</label>
                    <input asp-for="SoDienThoai" class="w-full px-3 py-2 border rounded-lg" />
                    <span asp-validation-for="SoDienThoai" class="text-red-500 text-sm"></span>
                </div>
                <div>
                    <label asp-for="Email" class="block text-sm font-medium text-gray-700 mb-2">Email</label>
                    <input asp-for="Email" class="w-full px-3 py-2 border rounded-lg" />
                    <span asp-validation-for="Email" class="text-red-500 text-sm"></span>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label asp-for="CCCD" class="block text-sm font-medium text-gray-700 mb-2">CCCD/CMND</label>
                    <input asp-for="CCCD" class="w-full px-3 py-2 border rounded-lg" />
                    <span asp-validation-for="CCCD" class="text-red-500 text-sm"></span>
                </div>
                <div>
                    <label asp-for="NgaySinh" class="block text-sm font-medium text-gray-700 mb-2">Ngày sinh</label>
                    <input asp-for="NgaySinh" type="date" class="w-full px-3 py-2 border rounded-lg" />
                    <span asp-validation-for="NgaySinh" class="text-red-500 text-sm"></span>
                </div>
            </div>

            <div>
                <label asp-for="DiaChi" class="block text-sm font-medium text-gray-700 mb-2">Địa chỉ</label>
                <textarea asp-for="DiaChi" rows="2" class="w-full px-3 py-2 border rounded-lg"></textarea>
                <span asp-validation-for="DiaChi" class="text-red-500 text-sm"></span>
            </div>

            <div class="flex justify-end space-x-3 pt-4">
                <a asp-action="Index" class="px-4 py-2 border rounded-lg hover:bg-gray-50">Hủy</a>
                <button type="submit" class="px-4 py-2 bg-yellow-500 text-white rounded-lg hover:bg-yellow-600">
                    <i class="fas fa-save mr-2"></i> Cập nhật
                </button>
            </div>
        </form>
    </div>
</div>