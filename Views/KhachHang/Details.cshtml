@model HeThongQuanLyPhongTro.Models.KhachHang

@{
    ViewData["Title"] = "Chi tiết khách hàng";
    var hopDongs = ViewBag.HopDongs as List<HeThongQuanLyPhongTro.Models.HopDong>;
}

<div class="max-w-4xl mx-auto">
    <div class="bg-white rounded-xl shadow-md overflow-hidden">
        <div class="bg-gradient-to-r from-purple-500 to-purple-600 px-6 py-4">
            <div class="flex justify-between items-center">
                <div>
                    <h1 class="text-xl font-bold text-white">Chi tiết khách hàng</h1>
                    <p class="text-purple-100">Mã KH: @Model.MaKhachHang</p>
                </div>
                <a asp-action="Index" class="text-white hover:text-purple-200">
                    <i class="fas fa-arrow-left mr-2"></i> Quay lại
                </a>
            </div>
        </div>

        <div class="p-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
                <div class="bg-gray-50 p-4 rounded-lg">
                    <p class="text-gray-500 text-sm">Họ tên</p>
                    <p class="font-semibold text-lg">@Model.HoTen</p>
                </div>
                <div class="bg-gray-50 p-4 rounded-lg">
                    <p class="text-gray-500 text-sm">Số điện thoại</p>
                    <p class="font-semibold">@Model.SoDienThoai</p>
                </div>
                <div class="bg-gray-50 p-4 rounded-lg">
                    <p class="text-gray-500 text-sm">Email</p>
                    <p class="font-semibold">@Model.Email</p>
                </div>
                <div class="bg-gray-50 p-4 rounded-lg">
                    <p class="text-gray-500 text-sm">CCCD/CMND</p>
                    <p class="font-semibold">@Model.CCCD</p>
                </div>
                <div class="bg-gray-50 p-4 rounded-lg">
                    <p class="text-gray-500 text-sm">Ngày sinh</p>
                    <p class="font-semibold">@(Model.NgaySinh?.ToString("dd/MM/yyyy") ?? "Chưa cập nhật")</p>
                </div>
                <div class="bg-gray-50 p-4 rounded-lg col-span-2">
                    <p class="text-gray-500 text-sm">Địa chỉ</p>
                    <p class="font-semibold">@Model.DiaChi</p>
                </div>
            </div>

            <!-- Danh sách hợp đồng -->
            @if (hopDongs != null && hopDongs.Any())
            {
                <div class="mt-6">
                    <h3 class="text-lg font-bold text-gray-800 mb-3">Lịch sử thuê phòng</h3>
                    <div class="space-y-2">
                        @foreach (var hd in hopDongs)
                        {
                            <div class="border p-3 rounded-lg">
                                <p><strong>Phòng:</strong> @hd.PhongNavigation?.TenPhong</p>
                                <p><strong>Thời gian:</strong> @hd.NgayBatDau?.ToString("dd/MM/yyyy") - @hd.NgayKetThuc?.ToString("dd/MM/yyyy")</p>
                                <p><strong>Trạng thái:</strong> @hd.TrangThai</p>
                            </div>
                        }
                    </div>
                </div>
            }

            <div class="flex justify-end space-x-3 pt-4 border-t mt-4">
                <a asp-action="Edit" asp-route-id="@Model.MaKhachHang" class="px-4 py-2 bg-yellow-500 text-white rounded-lg hover:bg-yellow-600">
                    <i class="fas fa-edit mr-2"></i> Sửa
                </a>
                <a asp-action="Delete" asp-route-id="@Model.MaKhachHang" class="px-4 py-2 bg-red-500 text-white rounded-lg hover:bg-red-600">
                    <i class="fas fa-trash mr-2"></i> Xóa
                </a>
            </div>
        </div>
    </div>
</div>